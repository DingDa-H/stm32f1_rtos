	.ucValue					= 0,
	.emFontSize 				= EM_FONT_SIZE,
	.emSelectStatus				= emUibuttonSelectStatus_Flase,
	.emNumberbutIsPressStatus	= emUibuttonIsPress_Flase,
	.emNumberPressStatusLast	= emUibuttonIsPress_Flase,
	.uCnt						= 0,
	.uCntThreshold				= 20,
	.vpfCallback				= 0,
};

/**
 * @brief 		[LedOn按钮控件]
 * @version 	
