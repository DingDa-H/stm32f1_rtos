
#include "stm32f1xx_hal.h"
#include "string.h"
#include <stdint.h>
#include <ui_text.h>
	
static uint8_t s_aucCalc[]     	  = "Calculator";			//计算器

static uint8_t s_aucLed[]  	   	  = "Led";					//Led

static uint8_t s_aucSerial[]   	  = "Serial Test";			//串口

static uint8_t s_aucSnake[]    	  = "Snake Game";			//贪吃蛇
static uint8_t s_aucSnakeWin[]    = "Game Win";				//贪吃蛇
static uint8_t s_aucSnakeFail[]   = "Game Fail";			//贪吃蛇

/**
 * @brief 		[Led单行文本]
 * @version 	
 * @data 			
 * @note 		
 */
static stTextItemTdf s_stSingleLineTest_Led = 
{
	//-1是因为字符串末尾的'\0'
	//(sizeof(s_aucLed)字符串数组总长， sizeof(s_aucLed[0])单个字符的长度
	//(sizeof(s_aucLed) / sizeof(s_aucLed[0]) - 1) 字符个数
	//EM_FONT_SIZE / 2,每个字符占像素宽度
	.x			= 64 - (sizeof(s_aucLed) / sizeof(s_aucLed[0]) - 1) / 2 * EM_FONT_SIZE / 2,
	.y			= 3,
	.ucData		= s_aucLed,
	.emFontSize = EM_FONT_SIZE,
};
//计算器
static stTextItemTdf s_stSingleLineTest_s_aucCalc = 
{
	.x			= 64 - (sizeof(s_aucCalc) / sizeof(s_aucCalc[0]) - 1) / 2 * EM_FONT_SIZE / 2,
	.y			= 0,
	.ucData		= s_aucCalc,
	.emFontSize = EM_FONT_SIZE,
};
//串口
static stTextItemTdf s_stSingleLineTest_s_aucSerial = 
{
	.x			= 64 - (sizeof(s_aucCalc) / sizeof(s_aucCalc[0]) - 1) / 2 * EM_FONT_SIZE / 2,
	.y			= 0,
	.ucData		= s_aucSerial,
	.emFontSize = EM_FONT_SIZE,
};

//贪吃蛇
static stTextItemTdf s_stSingleLineTest_s_aucSnake = 
{
	.x			= 64 - (sizeof(s_aucCalc) / sizeof(s_aucCalc[0]) - 1) / 2 * EM_FONT_SIZE / 2,
	.y			= 0,
	.ucData		= s_aucSnake,
	.emFontSize = EM_FONT_SIZE,
};

//贪吃蛇--Win
static stTextItemTdf s_stSingleLineTest_s_aucSnakeWin = 
{
	.x			= 64 - (sizeof(s_aucCalc) / sizeof(s_aucCalc[0]) - 1) / 2 * EM_FONT_SIZE / 2,
	.y			= 0,
	.ucData		= s_aucSnakeWin,
	.emFontSize = EM_FONT_SIZE,
};
//贪吃蛇--Fail
static stTextItemTdf s_stSingleLineTest_s_aucSnakeFail = 
{
	.x			= 64 - (sizeof(s_aucCalc) / sizeof(s_aucCalc[0]) - 1) / 2 * EM_FONT_SIZE / 2,
	.y			= 0,
	.ucData		= s_aucSnakeFail,
	.emFontSize = EM_FONT_SIZE,
};
// 子菜单文本项 结构体指针数组
