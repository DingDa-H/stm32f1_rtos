//};



/**
 * @brief  根据传入页面，显示对应单行文本
 * @param  eCurPage: 当前页面枚举
 */
void vShowSingleLineAll(emAllMenuTdf eCurPage)
{
    switch(eCurPage)
    {
        case emMenu_LED:
            vOledWriteStringToBuffer(s_stSingleLineTest_Led.x,
                                     s_stSingleLineTest_Led.y,
                                     s_stSingleLineTest_Led.ucData,
                                     s_stSingleLineTest_Led.emFontSize,
                                     emOledPixelShowMode_Positive,
                                     OLED);
            break;

        case emMenu_Calculator:
            vOledWriteStringToBuffer(s_stSingleLineTest_s_aucCalc.x,
                                     s_stSingleLineTest_s_aucCalc.y,
                                     s_stSingleLineTest_s_aucCalc.ucData,
                                     s_stSingleLineTest_s_aucCalc.emFontSize,
                                     emOledPixelShowMode_Positive,
                                     OLED);
            break;

        case emMenu_SerialTest:
            vOledWriteStringToBuffer(s_stSingleLineTest_s_aucSerial.x,
                                     s_stSingleLineTest_s_aucSerial.y,
									 s_stSingleLineTest_s_aucSerial.ucData,
                                     s_stSingleLineTest_s_aucSerial.emFontSize,
                                     emOledPixelShowMode_Positive,
                                     OLED);
            break;

        default:
            break;
    }
}
/**
 * @brief  根据传入页面，显示对应单行文本
 * @param  emSnakeGameStu: 贪吃蛇游戏状态
 */
void vShowSnakeGame(emSnakeGameStuTdf emSnakeGameStu)
{
    switch(emSnakeGameStu)
    {	// 游戏开始前状态
        case emSnakeGameStu0:
            vOledWriteStringToBuffer(s_stSingleLineTest_s_aucSnake.x,
                                     s_stSingleLineTest_s_aucSnake.y,
                                     s_stSingleLineTest_s_aucSnake.ucData,
                                     s_stSingleLineTest_s_aucSnake.emFontSize,
                                     emOledPixelShowMode_Positive,
                                     OLED);
            break;

		// 游戏开始后状态
        case emSnakeGameStu1:
//            vOledWriteStringToBuffer(s_stSingleLineTest_s_aucSnake.x,
//                                     s_stSingleLineTest_s_aucSnake.y,
//									 s_stSingleLineTest_s_aucSnake.ucData,
//                                     s_stSingleLineTest_s_aucSnake.emFontSize,
//                                     emOledPixelShowMode_Positive,
//                                     OLED);
            break;
		// 游戏胜利
		case emSnakeGamewin:
            vOledWriteStringToBuffer(s_stSingleLineTest_s_aucSnakeWin.x,
                                     s_stSingleLineTest_s_aucSnakeWin.y,
									 s_stSingleLineTest_s_aucSnakeWin.ucData,
                                     s_stSingleLineTest_s_aucSnakeWin.emFontSize,
                                     emOledPixelShowMode_Positive,
                                     OLED);
            break;
		// 游戏结束
		case emSnakeGamefail:
            vOledWriteStringToBuffer(s_stSingleLineTest_s_aucSnakeFail.x,
                                     s_stSingleLineTest_s_aucSnakeFail.y,
									 s_stSingleLineTest_s_aucSnakeFail.ucData,
                                     s_stSingleLineTest_s_aucSnakeFail.emFontSize,
                                     emOledPixelShowMode_Positive,
                                     OLED);
            break;

        default:
            break;
    }
}
