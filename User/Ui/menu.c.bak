#include "stm32f1xx_hal.h"
#include <string.h>
#include "oled_device.h"
#include <stdint.h>
#include "FreeRTOS.h"
#include "task.h"
#include "snake_app.h"
#include "menu.h"
#include "ui_text.h"   // .c 文件内引入，仅当前编译单元生效，不会循环包含

static emAllMenuTdf s_emCurrentPage = emMenu;
uint8_t ucGetMenuSelectedIndex(void);
extern TaskHandle_t s_hSerialTaskHandle;			// 串口任务句柄

static uint8_t s_ucWindowStart = 0;  					// 当前显示窗口第一行在数组中的索引
	
static uint8_t s_aucCalc[]   = "1.Calculator";			//计算器
static uint8_t s_aucLed[]    = "2.LED Control";			//led控制
static uint8_t s_aucSnake[]  = "3.Snake Game";			//贪吃蛇
static uint8_t s_aucSerial[] = "4.Serial Test";			//串口收发
static uint8_t s_auctest1[]  = "5.Test1";		//Test
static uint8_t s_auctest2[]  = "6.Test2";		//Test
static uint8_t s_auctest3[]  = "7.Test3";		//Test
static uint8_t s_auctest4[]  = "8.Test4";		//Test

// 菜单项 结构体数组
static stMenuItemTdf s_astMenuLines[] = {
    { 10,  0, s_aucCalc,   emOledFontSize_8x16,	emMenutextSelectStatus_True},
    { 10, 16, s_aucLed,    emOledFontSize_8x16,	emMenutextSelectStatus_Flase},		// y现在是动态绘制，这里不需要了
    { 10, 32, s_aucSnake,  emOledFontSize_8x16,	emMenutextSelectStatus_Flase},
    { 10, 48, s_aucSerial, emOledFontSize_8x16,	emMenutextSelectStatus_Flase},
	{ 10, 64, s_auctest1,  emOledFontSize_8x16,	emMenutextSelectStatus_Flase},
	{ 10, 80, s_auctest2,  emOledFontSize_8x16,	emMenutextSelectStatus_Flase},
	{ 10, 96, s_auctest3,  emOledFontSize_8x16,	emMenutextSelectStatus_Flase},
	{ 10, 112, s_auctest4,  emOledFontSize_8x16,emMenutextSelectStatus_Flase},
};
/**
 * @brief 		初始化函数待完善
 * @param 	
 * @data 			
 * @note 		
 */
void vMenuInit(void)
{
	s_astMenuLines->emSelectStatus = emMenutextSelectStatus_True;
	s_emCurrentPage				   = emMenu;
}

/**
 * @brief 		选中状态向下移动
 * @note 		此函数针对主菜单
 */
void vMenuSelectDown(void)
{	
	uint8_t i;
	i = ucGetMenuSelectedIndex();
	uint8_t ucCount = sizeof(s_astMenuLines) / sizeof(s_astMenuLines[0]);
	
	s_astMenuLines[i].emSelectStatus = emMenutextSelectStatus_Flase;

	if(i >= ucCount - 1)
	{
		i = 0;
	}
	else
	{
		i++;
	}		
	s_astMenuLines[i].emSelectStatus = emMenutextSelectStatus_True;
	
	 // 如果新选中项超出了当前窗口底部，窗口向下滚一行
    if (i >= s_ucWindowStart + MENU_VISIBLE_LINES)
    {
        s_ucWindowStart = i - MENU_VISIBLE_LINES + 1;
    }
    // 如果新选中项跑到了窗口顶部之上，窗口向上滚一行
	
	// 此时的i = 0 ,但是由于是从底部回到顶端，此时的s_ucWindowStart > 0;
    else if (i < s_ucWindowStart)
    {
        s_ucWindowStart = i;
    }
}
/**
 * @brief 		选中状态向上移动
 * @note 		此函数针对主菜单
 */
void vMenuSelectUp(void)
{
	uint8_t i;
	i = ucGetMenuSelectedIndex();
	s_astMenuLines[i].emSelectStatus = emMenutextSelectStatus_Flase;
	
	if(i <= 0)
	{
		i = sizeof(s_astMenuLines) / sizeof(s_astMenuLines[0]) - 1;		
	}
	else
	{
		i--;
	}
	s_astMenuLines[i].emSelectStatus = emMenutextSelectStatus_True;

	// 驱动窗口滚动
    if (i >= s_ucWindowStart + MENU_VISIBLE_LINES)
    {
        s_ucWindowStart = i - MENU_VISIBLE_LINES + 1;
    }
    else if (i < s_ucWindowStart)
    {
        s_ucWindowStart = i;
    }
}

/**
 * @brief 		确认键功能函数
 * @param 	
 * @data 		
 * @note 		进入当前选中的子页面
 */
void vMenuEnter(void)
{
	uint8_t i = ucGetMenuSelectedIndex();
	switch (i) {
	case 0: 
	{
		s_emCurrentPage = emMenu_Calculator;
		vOledClearBuffer();
		vCalcSystemInit(); 										// 计算器应用层初始化
		vCalcUiResetDraw();										// 初始绘制
	}
		break;
	case 1: s_emCurrentPage = emMenu_LED;     		break;		// 进入LED子菜单
	case 2:
	{
		s_emCurrentPage = emMenu_SnakeGame;
		vOledClearBuffer();      								// 进入蛇页面时擦除主菜单
		vOledRefreshFromBuffer(OLED);   						// ✅ 立即刷新，显示空白画面
		vSnakeInit();      										// 每次进入都重新初始化
	}
		break;
	case 3: 
		s_emCurrentPage = emMenu_SerialTest;
		xTaskNotifyGive(s_hSerialTaskHandle);
		break;
	}
}


/**
 * @brief 		取消键功能函数
 * @param 	
 * @data 		
 * @note 		返回上一级菜单（或退出）
 */
void vMenuCancel(void)
{
	s_emCurrentPage = emMenu;
}

/**
 * @brief 		返回当前页面函数
 * @note 		
 */
emAllMenuTdf emGetCurrentPage(void)
{
	return s_emCurrentPage;
}


//返回菜单结构体选中状态位置
uint8_t ucGetMenuSelectedIndex(void)
{
	uint8_t i;
	for(i = 0;i < sizeof(s_astMenuLines) / sizeof(s_astMenuLines[0]);i++)
    {
		//如果被选中就显示'>'字符
		if(s_astMenuLines[i].emSelectStatus == emMenutextSelectStatus_True)
		{
			return i;
		}
    }
	s_astMenuLines[0].emSelectStatus = emMenutextSelectStatus_True;
    return 0;
}

/**
 * @brief 		显示所有主页面选择框
 * @param 	
 * @data 			
 * @note 		
 */
void vShowMenuTextAll(void)
{
	uint8_t i;
	for(i = 0;i < MENU_VISIBLE_LINES;i++)
    {
		uint8_t dataIndex = s_ucWindowStart + i;   // 对应数组中的实际索引
		
        if (dataIndex >= sizeof(s_astMenuLines) / sizeof(s_astMenuLines[0]))
            break; 								   // 超出数组范围，停止绘制

        // 计算这一行在屏幕上的 Y 坐标
        uint8_t y = i * (uint8_t)EM_FONT_SIZE;
		
		//如果被选中就显示'>'字符
		if(s_astMenuLines[dataIndex].emSelectStatus == emMenutextSelectStatus_True)
		{
			vOledWriteOneCharToBuffer(0,y,'>',EM_FONT_SIZE,
									  emOledPixelShowMode_Positive,
									  OLED);
		}
		vOledWriteStringToBuffer(s_astMenuLines[dataIndex].x,
								 y,
								 s_astMenuLines[dataIndex].ucData,
								 EM_FONT_SIZE,
								 emOledPixelShowMode_Positive,
								 OLED);
    }
}
//@brief 		显示主菜单函数
//@note			
void vShowMenu(void)
{
	vShowMenuTextAll();						//显示主菜单
}

//@brief 		显示计算器界面 
//@note			
void vShowCalculatorMenu(void)
{
	emAllMenuTdf page = emGetCurrentPage();
	vShowSingleLineAll(page);					//显示led单行文本
}


//@brief 		显示LED控制界面 
//@note			
void vShowLEDMenu(void)
{
	emAllMenuTdf page = emGetCurrentPage();
	vShowSingleLineAll(page);					//显示led单行文本
	vShowUibuttonTextAll();						//显示按钮
	vShowNumberSelectorAll();					//显示数字选择器
	vBtnScanAndExecute();				    	//遍历所有回调函数
}

//@brief 		显示贪吃蛇游戏界面 
//@note			
void vShowSnakeMenu(void)
{
	emSnakeGameStuTdf emSnakeGameStu = emGetSnakeGameCurrentStu();
	vShowSnakeGame(emSnakeGameStu);				//显示游戏不同状态文本
	if(emSnakeGameStu == emSnakeGameStu_Idle 
	|| emSnakeGameStu == emSnakeGameStu_Win
	|| emSnakeGameStu == emSnakeGameStu_Fail)
	{
		vShowUibuttonTextAll();					//显示按钮
		vBtnScanAndExecute();				    //遍历所有按钮回调函数
		vOledRefreshFromBuffer(OLED);
	}
	
	if (emSnakeGameStu == emSnakeGameStu_Running)
	{
		DrawSnakeGame();
	}
	if(emSnakeGameStu == emBackMenu)			//如果是回退状态就回到主菜单（这一步做的不完美）
	{
		vSnakeSetStu(emSnakeGameStu_Idle);
		vMenuCancel();
        return;
    }
}

//@brief 		显示串口界面 
//@note			
void vShowSerialMenu(void)
{
	emAllMenuTdf page = emGetCurrentPage();
	vShowSingleLineAll(page);				//显示led单行文本
}

/**
 * @brief 		当前页面显示函数
 * @version 	
 * @data 			
* @note 		根据不同的状态/操作显示对应页面
 */

void vCurrentPageShow(void)
{	    
    // ==============================================
    // ✅ 关键修复：计算器页面 不允许清屏！！！
    // ==============================================
    if (s_emCurrentPage != emMenu_Calculator && s_emCurrentPage != emMenu_SnakeGame)
    {
        vOledClearBuffer();
    }

    switch (s_emCurrentPage)
    {
        case emMenu:
            vShowMenu();     				// 显示主菜单
            break;		
		
        case emMenu_Calculator:		
            vShowCalculatorMenu();  		// 计算器界面
            break;		
		
        case emMenu_LED:		
            vShowLEDMenu();          		// 显示LED控制界面
            break;		
        
		case emMenu_SnakeGame:				// 贪吃蛇显示界面
			vShowSnakeMenu();
            break;	
        
		case emMenu_SerialTest:
			vShowSerialMenu();          	// 显示串口界面
            break;
        
        default:
            break;
    }
	// ✅ 蛇页面由 DrawSnakeGame 自行刷新，这里不要再刷新
	if (s_emCurrentPage != emMenu_SnakeGame)
    {
        vOledRefreshFromBuffer(OLED);
    }

}
